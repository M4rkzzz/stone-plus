{
  "name": "stone-desktop",
  "version": "0.9.2",
  "private": true,
  "description": "Stone+ — Unofficial community fork of Stone",
  "author": {
    "name": "Stone+ Contributors"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/M4rkzzz/stone-plus",
  "repository": {
    "type": "git",
    "url": "https://github.com/M4rkzzz/stone-plus.git"
  },
  "bugs": {
    "url": "https://github.com/M4rkzzz/stone-plus/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "electron-vite build",
    "build:web": "vite build",
    "visual:check": "node scripts/visual-check.mjs",
    "smoke:electron": "node scripts/electron-smoke.mjs",
    "release:check": "node scripts/validate-release-tag.mjs",
    "frp:fetch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-frpc.ps1",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.6",
    "electron-updater": "^6.8.9",
    "fetch-socks": "^1.3.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semver": "^7.7.3",
    "smol-toml": "^1.7.0",
    "undici": "^7.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.7.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "io.github.m4rkzzz.stoneplus",
    "productName": "Stone+",
    "publish": {
      "provider": "github",
      "owner": "M4rkzzz",
      "repo": "stone-plus"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "NOTICE",
        "to": "NOTICE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "MODIFICATIONS.md",
        "to": "MODIFICATIONS.md"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "artifactName": "StonePlus-${version}-macos-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "build/frp/frpc.exe",
          "to": "frp/frpc.exe"
        },
        {
          "from": "build/frp/LICENSE.frp.txt",
          "to": "frp/LICENSE.frp.txt"
        }
      ],
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "StonePlus-${version}-windows-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stone+",
      "uninstallDisplayName": "Stone+ ${version}",
      "runAfterFinish": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "displayLanguageSelector": false,
      "license": "LICENSE",
      "include": "build/installer.nsh"
    },
    "portable": {
      "artifactName": "StonePlus-${version}-windows-${arch}-portable.${ext}"
    },
    "linux": {
      "category": "Development",
      "icon": "build/icons",
      "executableName": "stone-plus",
      "artifactName": "StonePlus-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
